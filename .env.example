# === RoomMind Stanford 独立端口（与 roommind 原版可并存）===
API_HOST=0.0.0.0
API_PORT=8810
ADMIN_PORT=5182
CLIENT_PORT=5183
POSTGRES_PORT=5432
REDIS_PORT=6379
PUBLIC_HOST=auto

DATABASE_URL=postgresql+asyncpg://roommind:roommind_dev@localhost:5432/roommind_stanford
REDIS_URL=redis://localhost:6379/1
POSTGRES_USER=roommind
POSTGRES_PASSWORD=roommind_dev
